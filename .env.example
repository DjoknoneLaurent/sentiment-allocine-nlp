# Environnement
ENVIRONMENT=development
LOG_LEVEL=INFO

# Modèle en production
MODEL_NAME=camembert-base
MODEL_PATH=./models/production/camembert_finetuned
MAX_LENGTH=512

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=sentiment_allocine

# HuggingFace
HF_DATASET_NAME=allocine
HF_TOKEN=your_token_here
